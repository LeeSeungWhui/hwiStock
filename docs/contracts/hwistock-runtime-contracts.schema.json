{
  "schema_catalog_version": "hwistock.runtime_contracts/v0",
  "updated_at": "2026-06-05",
  "owner_unit": "HWISTOCK-UNIT-016",
  "common_required_fields": [
    "schema_version",
    "artifact_id",
    "artifact_type",
    "run_id",
    "trading_date",
    "environment",
    "created_at_kst",
    "collected_at_kst",
    "valid_until",
    "content_hash",
    "redaction_status",
    "producer",
    "input_refs",
    "validation"
  ],
  "common_field_specs": {
    "schema_version": {
      "type": "string"
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^art_[a-z0-9_:-]+$"
    },
    "artifact_type": {
      "type": "string"
    },
    "run_id": {
      "type": "string",
      "pattern": "^run_[a-z0-9_:-]+$"
    },
    "trading_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "environment": {
      "type": "string",
      "enum": [
        "paper",
        "sandbox",
        "docs_only"
      ]
    },
    "created_at_kst": {
      "type": "string",
      "format": "kst_datetime"
    },
    "collected_at_kst": {
      "type": "string",
      "format": "kst_datetime"
    },
    "valid_until": {
      "type": "string",
      "format": "kst_datetime"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "redaction_status": {
      "type": "string",
      "enum": [
        "none",
        "partial",
        "full"
      ]
    },
    "producer": {
      "type": "string"
    },
    "input_refs": {
      "type": "array"
    },
    "validation": {
      "type": "object",
      "required_fields": [
        "ok",
        "validator",
        "validated_at_kst"
      ],
      "fields": {
        "ok": {
          "type": "boolean"
        },
        "validator": {
          "type": "string"
        },
        "validated_at_kst": {
          "type": "string",
          "format": "kst_datetime"
        },
        "errors": {
          "type": "array"
        }
      }
    }
  },
  "id_formulas": {
    "trade_doc_id": "sha256(run_id + trading_date + decision_bucket_kst + input_manifest_hash)",
    "intent_id": "sha256(trade_doc_id + trade_action_id + ticker + side + normalized_order_rule_hash)",
    "client_order_key": "sha256(intent_id + execution_attempt_no)"
  },
  "freshness_ttl_seconds": {
    "portfolio_order_state_before_submit": 5,
    "current_price_quote": 5,
    "realtime_orderbook": 3,
    "realtime_heartbeat_gap": 10,
    "ranking_analysis_snapshot": 60,
    "pro_hourly_tolerance": 600,
    "flash_trade_document": 600,
    "calendar_session_before_submit": 60,
    "kis_rest_ranking_snapshot": 180,
    "flash_decision_interval": 600
  },
  "order_state_machine": {
    "INTENT_CREATED": [
      "GATE_REJECTED",
      "RESERVED",
      "EXPIRED"
    ],
    "GATE_REJECTED": [
      "RECONCILED"
    ],
    "RESERVED": [
      "SUBMITTING",
      "EXPIRED",
      "ERROR_LOCKED"
    ],
    "SUBMITTING": [
      "SUBMITTED_ACKED",
      "SUBMIT_UNKNOWN",
      "BROKER_REJECTED",
      "ERROR_LOCKED"
    ],
    "SUBMITTED_ACKED": [
      "PARTIALLY_FILLED",
      "FILLED",
      "CANCEL_REQUESTED",
      "BROKER_REJECTED",
      "RECONCILED"
    ],
    "SUBMIT_UNKNOWN": [
      "SUBMITTED_ACKED",
      "BROKER_REJECTED",
      "RECONCILED",
      "ERROR_LOCKED"
    ],
    "BROKER_REJECTED": [
      "RECONCILED"
    ],
    "PARTIALLY_FILLED": [
      "FILLED",
      "CANCEL_REQUESTED",
      "RECONCILED",
      "ERROR_LOCKED"
    ],
    "FILLED": [
      "RECONCILED"
    ],
    "CANCEL_REQUESTED": [
      "CANCELED",
      "PARTIALLY_FILLED",
      "FILLED",
      "ERROR_LOCKED"
    ],
    "CANCELED": [
      "RECONCILED"
    ],
    "EXPIRED": [
      "RECONCILED"
    ],
    "RECONCILED": [],
    "ERROR_LOCKED": []
  },
  "reject_codes": [
    "schema_invalid",
    "artifact_not_finalized",
    "manifest_hash_mismatch",
    "stale_market_data",
    "stale_portfolio_state",
    "stale_order_state",
    "session_invalid",
    "already_holding_symbol",
    "pending_order_exists",
    "active_exit_order_exists",
    "prior_trade_document_still_valid",
    "cooldown_active",
    "position_locked",
    "scale_in_not_authorized",
    "cash_reserve_breach",
    "holding_slot_breach",
    "paper_only_guard_failed",
    "unsupported_broker_capability",
    "duplicate_trade_doc",
    "duplicate_intent",
    "submit_unknown_requires_reconciliation"
  ],
