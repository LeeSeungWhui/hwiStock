  "common_field_specs": {
    "schema_version": {
      "type": "string"
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^art_[a-z0-9_:-]+$"
    },
    "artifact_type": {
      "type": "string"
    },
    "run_id": {
      "type": "string",
      "pattern": "^run_[a-z0-9_:-]+$"
    },
    "trading_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "environment": {
      "type": "string",
      "enum": [
        "paper",
        "sandbox",
        "docs_only"
      ]
    },
    "created_at_kst": {
      "type": "string",
      "format": "kst_datetime"
    },
    "collected_at_kst": {
      "type": "string",
      "format": "kst_datetime"
    },
    "valid_until": {
      "type": "string",
      "format": "kst_datetime"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "redaction_status": {
      "type": "string",
      "enum": [
        "none",
        "partial",
        "full"
      ]
    },
    "producer": {
      "type": "string"
    },
    "input_refs": {
      "type": "array"
    },
    "validation": {
      "type": "object",
      "required_fields": [
        "ok",
        "validator",
        "validated_at_kst"
      ],
      "fields": {
        "ok": {
          "type": "boolean"
        },
        "validator": {
          "type": "string"
        },
        "validated_at_kst": {
          "type": "string",
          "format": "kst_datetime"
        },
        "errors": {
          "type": "array"
        }
      }
    },
    "publication": {
      "type": "object",
      "required_fields": [
        "path",
        "temp_path",
        "manifest_ref",
        "ready_marker",
        "byte_size",
        "content_hash",
        "finalized_at_kst",
        "atomic_rename_complete",
        "manifest_hash_verified"
      ],
      "fields": {
        "path": {
          "type": "string"
        },
        "temp_path": {
          "type": "string"
        },
        "manifest_ref": {
          "type": "string"
        },
        "ready_marker": {
          "type": "boolean",
          "const": true
        },
        "byte_size": {
          "type": "integer",
          "minimum": 1
        },
        "content_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "finalized_at_kst": {
          "type": "string",
          "format": "kst_datetime"
        },
        "atomic_rename_complete": {
          "type": "boolean",
          "const": true
        },
        "manifest_hash_verified": {
          "type": "boolean",
          "const": true
        }
      }
    }
  },
  "id_formulas": {
    "trade_doc_id": "tdoc_ + sha256(run_id + trading_date + decision_bucket_kst + input_manifest_hash)",
    "intent_id": "intent_ + sha256(trade_doc_id + trade_action_id + ticker + side + normalized_order_rule_hash)",
    "client_order_key": "cok_ + sha256(intent_id + execution_attempt_no)"
  },
  "freshness_ttl_seconds": {
    "portfolio_order_state_before_submit": 5,
    "current_price_quote": 5,
    "realtime_orderbook": 3,
    "realtime_heartbeat_gap": 10,
    "ranking_analysis_snapshot": 60,
    "pro_hourly_tolerance": 600,
    "flash_trade_document": 600,
    "calendar_session_before_submit": 60,
    "kis_rest_ranking_snapshot": 180,
    "flash_decision_interval": 600
  },
  "order_state_machine": {
    "INTENT_CREATED": [
